# =============================================================================
# Variables del docker-compose. Copia este archivo a .env y rellena los valores
# (sobre todo LLM_API_KEY). El resto vale tal cual para una instalación local.
#
#   cp .env.docker.example .env
# =============================================================================

# ─── Base de datos MySQL (uso interno del stack, no se expone al host) ──────
MYSQL_ROOT_PASSWORD=biosim_root_local
MYSQL_DATABASE=biosim
MYSQL_USER=biosim
MYSQL_PASSWORD=biosim_local

# ─── Backend FastAPI ────────────────────────────────────────────────────────
# Genera una clave nueva con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esta_clave_por_una_generada_localmente

# ─── Proveedor LLM ──────────────────────────────────────────────────────────
# Por defecto: Groq Cloud (recomendado, cuota gratuita generosa)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=gsk_pega_aqui_tu_clave_de_groq

# ─── Modo offline alternativo (Ollama Local) ────────────────────────────────
# Para activarlo:
#   1. Comenta las tres lineas LLM_* de arriba.
#   2. Descomenta las tres siguientes.
#   3. Arranca con:   docker compose --profile offline up
#   4. La primera vez, descarga el modelo:
#        docker exec biosim-ollama ollama pull qwen2.5:7b-instruct
#
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_API_KEY=ollama
