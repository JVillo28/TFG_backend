# ─────────────────────────────────────────────────────────────
# Configuración del entorno — copia este archivo a .env y rellena
# ─────────────────────────────────────────────────────────────

# Entorno de la aplicación
APP_ENV=development

# Base de datos (MySQL por defecto)
DATABASE_URL=mysql+pymysql://usuario:contraseña@localhost:3306/biosim

# Genera una clave nueva con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=secret_key_for_security_api

# Orígenes permitidos por CORS (separados por comas)
ALLOWED_ORIGINS=http://localhost:4200

# ─────────────────────────────────────────────────────────────
# Configuración del proveedor LLM
# ─────────────────────────────────────────────────────────────

# Opción A — Groq Cloud (recomendado, cuota gratuita generosa)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=gsk_GROK_KEY

# Opción B — Ollama local (ejecución offline). Descomenta y
# comenta las tres líneas anteriores para usarlo:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_API_KEY=ollama
