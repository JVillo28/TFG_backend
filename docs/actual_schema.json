{
    "title": "Simulation Configuration",
    "description": "Configuration schema for simulation parameters",
    "type": "object",
    "properties": {
        "generalConfiguration": {
            "title": "General Configuration",
            "description": "General configuration for the simulation",
            "type": "object",
            "properties": {
                "totalTries": {
                    "title": "Total Tries",
                    "description": "Maximum tries for putting a body into the environment",
                    "type": "integer",
                    "minimum": 1
                },
                "dirOutput": {
                    "title": "Output Directory",
                    "description": "Directory path where simulation output will be saved",
                    "type": "string"
                },
                "fileOutput": {
                    "title": "Output File",
                    "description": "Name of the output file",
                    "type": "string"
                },
                "simulationName": {
                    "title": "Simulation Name",
                    "description": "Name identifier for the simulation",
                    "type": "string"
                },
                "simulationType": {
                    "title": "Simulation Type",
                    "description": "Type of simulation to run",
                    "type": "string",
                    "enum": ["basic"]
                },
                "activateGUI": {
                    "title": "Activate GUI",
                    "description": "Enable or disable graphical user interface",
                    "type": "boolean",
                    "default": false
                },
                "saveSimulationEvery": {
                    "title": "Save Simulation Every",
                    "description": "Frequency of simulation checkpoints (in steps)",
                    "type": "integer"
                },
                "stepsRandomRebound": {
                    "title": "Steps Random Rebound",
                    "type": "integer"
                },
                "restoreCheckpoint": {
                    "title": "Restore Checkpoint",
                    "type": "boolean",
                    "default": false
                }
            },
            "required": ["totalTries", "dirOutput", "fileOutput", "simulationName", "simulationType"]
        }
    },
    "required": ["generalConfiguration"]
}